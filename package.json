{
  "name": "grainy",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@11.0.7",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --no-cache",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/patch-opennext.mjs",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "db:migration:generate": "drizzle-kit generate",
    "db:migration:apply": "drizzle-kit migrate"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.19",
    "@opennextjs/cloudflare": "^1.19.9",
    "@t3-oss/env-nextjs": "0.13.11",
    "better-auth": "1.6.18",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "openssl": "2.0.0",
    "react": "^19.1.7",
    "react-dom": "^19.1.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.43",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.7",
    "drizzle-kit": "0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "pg": "8.21.0",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5.7.4",
    "wrangler": "^4.100.0"
  }
}
